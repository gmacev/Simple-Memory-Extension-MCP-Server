{
  "name": "simple-memory-extension-mcp-server",
  "version": "2.3.1",
  "description": "A local-first, generic persistent memory layer for MCP agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "simple-memory": "dist/index.js",
    "memoryctl": "dist/cli.js"
  },
  "files": [
    "dist",
    "python",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs setup",
    "update": "node scripts/setup.mjs update",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "memoryctl": "node dist/cli.js",
    "probe:live": "node scripts/live-probe.mjs",
    "probe:http": "node scripts/http-probe.mjs",
    "probe:queue": "node scripts/queue-probe.mjs",
    "format": "biome check --write src scripts",
    "lint": "biome check src scripts"
  },
  "keywords": [
    "mcp",
    "memory",
    "semantic-search",
    "sqlite",
    "agents",
    "qwen"
  ],
  "author": "gmacev",
  "license": "MIT",
  "engines": {
    "node": ">=22.9.0 <23 || >=24 <25 || >=26 <27",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "jose": "6.2.3",
    "sqlite-vec": "0.1.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/node": "22.20.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true
  }
}
