# All settings are optional. Uncomment only what you want to override.

# General
SIMPLE_MEMORY_LOG_LEVEL=info
# SIMPLE_MEMORY_DATA_DIR=<absolute-data-directory>
# SIMPLE_MEMORY_DB_PATH=<absolute-database-file>
# SIMPLE_MEMORY_MODELS=enabled
# SIMPLE_MEMORY_DEVICE=auto
# SIMPLE_MEMORY_LOCAL_FILES_ONLY=false
# SIMPLE_MEMORY_MODEL_TIMEOUT_MS=600000

# Transport: stdio or http
# SIMPLE_MEMORY_TRANSPORT=stdio
# SIMPLE_MEMORY_HTTP_HOST=127.0.0.1
# SIMPLE_MEMORY_HTTP_PORT=3000
# SIMPLE_MEMORY_HTTP_TOKEN=<bearer-token>
# SIMPLE_MEMORY_HTTP_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Retrieval
# SIMPLE_MEMORY_LEXICAL_CANDIDATES=100
# SIMPLE_MEMORY_SEMANTIC_CANDIDATES=100
# SIMPLE_MEMORY_RERANK_CANDIDATES=30

# Models. Default revisions are pinned internally.
# SIMPLE_MEMORY_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# SIMPLE_MEMORY_EMBEDDING_REVISION=<hugging-face-revision>
# SIMPLE_MEMORY_EMBEDDING_DIMENSION=1024
# SIMPLE_MEMORY_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
# SIMPLE_MEMORY_RERANKER_REVISION=<hugging-face-revision>
# SIMPLE_MEMORY_QUERY_INSTRUCTION=<query-instruction>
# SIMPLE_MEMORY_RERANK_INSTRUCTION=<rerank-instruction>
# SIMPLE_MEMORY_EMBED_BATCH_SIZE=8
# SIMPLE_MEMORY_RERANK_BATCH_SIZE=4

# Python runtime
# SIMPLE_MEMORY_PYTHON=<absolute-python-executable>
# SIMPLE_MEMORY_PYTHON_PROJECT=<absolute-python-project-directory>

# Setup-only overrides
# SIMPLE_MEMORY_TORCH_BACKEND=auto
# SIMPLE_MEMORY_UV=<absolute-uv-executable>

# Standard Hugging Face cache override
# HF_HOME=<absolute-hugging-face-cache-directory>
